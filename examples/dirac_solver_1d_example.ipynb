    "yukawa_potential = YukawaPotential(strength=1.0, range=0.5).core_potential\n",
    "problem_yukawa = DiracProblemBuilder() \\\n",
    "    .set_grid(grid) \\\n",
    "    .set_initial_state(initial_state) \\\n",
    "    .set_potential(yukawa_potential) \\\n",
    "    .set_boundary_condition(boundary_condition) \\\n",
    "    .set_time_parameters(time_step=0.001, total_time=2.0) \\\n",
    "    .build()\n",
    "solver_yukawa = DiracSolver(problem_yukawa)\n",
    "solver_yukawa.run_simulation()\n",
    "solver_yukawa.plot_probability_density()"
   ]
